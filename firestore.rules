rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasMyUserDoc() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function myRole() {
      return hasMyUserDoc()
        ? get(userPath(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return signedIn() && myRole() == 'admin';
    }

    function isTrainer() {
      return signedIn() && myRole() == 'trainer';
    }

    function isStaff() {
      return isAdmin() || isTrainer();
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function resourceBelongsToMe() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function newResourceBelongsToMe() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isStaff();

      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow read: if signedIn();

      allow create: if signedIn();

      allow update: if isStaff()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'entriesReserved',
              'reservedEntries',
              'usedEntries',
              'availableEntries',
              'updatedAt',
              'lastReservationAt',
              'lastCancelledReservationAt'
            ])
        );

      allow delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if signedIn();

      allow create: if signedIn();

      allow update: if signedIn();

      allow delete: if isAdmin();
    }

    match /trainingSessions/{sessionId} {
      allow read: if true;

      allow create: if isStaff();

      allow update: if isStaff()
        || (
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'reservedCount',
              'updatedAt'
            ])
        );

      allow delete: if isAdmin();
    }

    match /trainingTypes/{typeId} {
      allow read: if true;

      allow create, update: if isStaff();

      allow delete: if isAdmin();
    }

    match /scheduleTemplates/{templateId} {
      allow read: if signedIn();

      allow create, update: if isStaff();

      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isStaff();

      allow create: if signedIn();

      allow update, delete: if false;
    }

    match /public_messages/{messageId} {
      allow read: if true;

      allow create, update: if isStaff();

      allow delete: if isAdmin();
    }

    match /accountDeletionRequests/{requestId} {
      allow read: if signedIn();

      allow create: if signedIn();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow read: if isStaff();

      allow create, update: if
        request.resource.data.token == tokenId
        && request.resource.data.keys().hasOnly([
          'token',
          'userId',
          'isLoggedIn',
          'languageCode',
          'platform',
          'updatedAt'
        ])
        && request.resource.data.languageCode in [
          'sk',
          'en',
          'cs',
          'de',
          'fr',
          'pl',
          'hu',
          'uk',
          'ru',
          'sr'
        ];

      allow delete: if signedIn();
    }

    match /membershipPlans/{planId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if signedIn();

      allow create, update, delete: if false;
    }

    match /discount_requests/{requestId} {
      allow read: if isStaff()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
        );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}