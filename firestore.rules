rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return signedIn() && myUserDoc().exists()
        ? myUserDoc().data.role
        : null;
    }

    function isAdmin() {
      return signedIn() && myRole() == 'admin';
    }

    function isTrainer() {
      return signedIn() && myRole() == 'trainer';
    }

    function isStaff() {
      return isAdmin() || isTrainer();
    }

    function isUserDocOwner() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function isNewUserDocOwner() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function onlyAllowedUserSelfFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'displayName',
          'publicName',
          'phone',
          'photoUrl',
          'pendingEmail',
          'emailChangeRequestedAt',
          'emailChangeSource',
          'emailChangeCompletedAt',
          'previousEmail',
          'termsAcceptedAt',
          'privacyAcceptedAt',
          'updatedAt'
        ]);
    }

    function onlyAllowedUserCreateFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'userId',
        'email',
        'displayName',
        'publicName',
        'phone',
        'photoUrl',
        'role',
        'isActive',
        'createdAt',
        'updatedAt',
        'termsAcceptedAt',
        'privacyAcceptedAt',
        'pendingEmail',
        'emailChangeRequestedAt',
        'emailChangeSource',
        'emailChangeCompletedAt',
        'previousEmail'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();

      allow create: if isOwner(userId)
        && onlyAllowedUserCreateFields()
        && (!('role' in request.resource.data) || request.resource.data.role == 'user')
        && (!('isActive' in request.resource.data) || request.resource.data.isActive == true);

      allow update: if
        (
          isOwner(userId)
          && onlyAllowedUserSelfFieldsChanged()
          && request.resource.data.role == resource.data.role
          && request.resource.data.isActive == resource.data.isActive
        )
        || isStaff();

      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow read: if isStaff() || isUserDocOwner();

      allow create: if isStaff()
        || (
          signedIn()
          && request.resource.data.userId == request.auth.uid
        );

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if isStaff() || isUserDocOwner();

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isStaff()
        || (
          isUserDocOwner()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'status',
              'entryStatus',
              'cancelledAt',
              'cancelledBy',
              'cancelledReason',
              'updatedAt'
            ])
        );

      allow delete: if isAdmin();
    }

    match /trainingSessions/{sessionId} {
      allow read: if true;

      allow create, update: if isStaff();

      allow delete: if isAdmin();
    }

    match /trainingTypes/{typeId} {
      allow read: if true;

      allow create, update: if isStaff();

      allow delete: if isAdmin();
    }

    match /scheduleTemplates/{templateId} {
      allow read: if signedIn();

      allow create, update: if isStaff();

      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isStaff();

      allow create: if signedIn();

      allow update, delete: if false;
    }

    match /public_messages/{messageId} {
      allow read: if true;

      allow create, update: if isStaff();

      allow delete: if isAdmin();
    }

    match /accountDeletionRequests/{requestId} {
      allow read: if isStaff()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
        );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow read: if isAdmin();

      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /membershipPlans/{planId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isStaff()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
        );

      allow create, update, delete: if false;
    }

    match /discount_requests/{requestId} {
      allow read: if isStaff()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
        );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}